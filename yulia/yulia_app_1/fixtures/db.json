    ]
  }
},
{
  "model": "yulia_app_1.coffee",
  "pk": 3,
  "fields": {
    "title": "Tiramisu",
    "slug": "Tiramisu3",
    "content": "Тирамису́ (итал. tiramisù, «вознеси меня» от гл. tira — тяни, mi — меня, su — вверх) — итальянский многослойный десерт, в состав которого входят сыр маскарпоне, кофе (обычно эспрессо), куриные яйца, сахар и печенье савоярди. Как правило, десерт припудривают какао-порошком[1]. Возможна вариация с добавлением грецкого ореха.\n\nЕсть необычные адаптации рецепта, согласно которым какао-порошок заменяют тёртым шоколадом, савоярди — бисквитом, кофейную пропитку — фруктовой или алкогольной (обычно это марсала, мадера, амаретто), а в некоторых вариациях тирамису может напоминать пудинг или кекс.",
    "time_create": "2024-12-10T12:23:38.032Z",
    "time_update": "2024-12-14T15:54:59.425Z",
    "is_published": true,
    "cat": 3,
    "gost": 1,
    "photo": "",
    "tag": [
      2,
      3
    ]
  }
},
